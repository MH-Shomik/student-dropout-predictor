# ─────────────────────────────────────────────
#  Python virtual environment (very large, never commit)
# ─────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────────────────────
#  Python bytecode & cache
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ─────────────────────────────────────────────
#  Jupyter Notebook checkpoints
# ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─────────────────────────────────────────────
#  Distribution / packaging
# ─────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ─────────────────────────────────────────────
#  OS generated files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
#  Editor & IDE files
# ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ─────────────────────────────────────────────
#  Environment variables / secrets
# ─────────────────────────────────────────────
.env
.env.*
*.secret

# ─────────────────────────────────────────────
#  Misc
# ─────────────────────────────────────────────
*.log
*.tmp
